PROJECT_NAME="Agent Translator Middleware"
API_STR="/api/v1"

# Postgres
POSTGRES_SERVER=db
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=translator_db
DATABASE_URL=postgresql+asyncpg://admin:password@db:5432/translator_db

# RabbitMQ
RABBITMQ_USER=user
RABBITMQ_PASS=password
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBIT_URL=amqp://user:password@rabbitmq:5672/
